{
  "name": "aidm_frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@12.0.0",
  "engines": {
    "node": "24.18.0",
    "npm": "12.0.0"
  },
  "scripts": {
    "dev": "vite",
    "test": "npm run typecheck && npm run lint && npm run test:unit",
    "test:unit": "vitest run",
    "typecheck": "node ./node_modules/typescript-7/bin/tsc -b",
    "build": "node ./node_modules/typescript-7/bin/tsc -b && vite build",
    "bundle:budget": "node scripts/check-bundle-budget.mjs",
    "smoke:browser": "node scripts/browser-smoke.cjs",
    "smoke:visual": "node scripts/visual-smoke.cjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "cannon-es": "^0.20.0",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "socket.io-client": "^4.8.3",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-7": "npm:typescript@^7.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "fsevents@2.3.3": true,
    "fsevents@2.3.2": true
  }
}
